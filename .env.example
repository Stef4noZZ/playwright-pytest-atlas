# Copy this file to `.env` and adjust for your environment.
# Never commit `.env` to source control.

# Logical environment label (local / dev / staging / prod)
QA_ENVIRONMENT=local

# Target system under test
QA_BASE_URL=https://playwright.dev
QA_API_BASE_URL=https://jsonplaceholder.typicode.com

# Browser settings
QA_BROWSER=chromium
QA_HEADLESS=true
QA_SLOW_MO_MS=0

# Timeouts (milliseconds)
QA_DEFAULT_TIMEOUT_MS=30000
QA_NAVIGATION_TIMEOUT_MS=30000

# Artifact capture
QA_RECORD_VIDEO=false
QA_RECORD_TRACE=retain-on-failure
QA_CAPTURE_SCREENSHOT=only-on-failure

# --- Authentication (optional) -----------------------------------------------
# Leave blank to run tests anonymously. Set these and the auth fixtures
# (`storage_state_path`, `api_token`, `ui_login`) activate automatically.
# Never commit real credentials.

# QA_USERNAME=
# QA_PASSWORD=
# QA_OTP_SECRET=                          # base32 TOTP secret if 2FA is enabled

# OAuth2 / OIDC token endpoint, e.g. Keycloak:
# QA_AUTH_TOKEN_URL=https://your-host/auth/realms/master/protocol/openid-connect/token
# QA_AUTH_LOGOUT_URL=https://your-host/auth/realms/master/protocol/openid-connect/logout
# QA_AUTH_CLIENT_ID=ocp
# QA_AUTH_GRANT_TYPE=password

# Optional generic API key
# QA_API_KEY=
